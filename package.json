{
  "name": "eslint-plugin-branded-types",
  "version": "0.1.0",
  "description": "ESLint rules enforcing branded type safety -- ban casts, direct construction, and mutation of Zod branded types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prettier": "prettier --check \"src/**/*.ts\" \"*.md\" \"*.json\"",
    "prettier:fix": "prettier --write \"src/**/*.ts\" \"*.md\" \"*.json\"",
    "build": "tsc",
    "prepare": "tsc",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "typescript",
    "zod",
    "branded-types",
    "type-safety"
  ],
  "license": "MIT",
  "author": "John Pearson",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnpphd/eslint-plugin-branded-types"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint": "^9.6.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
